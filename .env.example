# =============================================================================
# .env.example — 环境变量模板
# 复制为 .env 并填入实际值：cp .env.example .env
# 警告：.env 文件含真实密钥，禁止提交到 git
# =============================================================================

# ----------------------------------------------------------------------------
# Anthropic / LLM 配置（必填）
# ----------------------------------------------------------------------------
# API Key（支持官方 key 或第三方中转 key）
LLM_API_KEY=your-dashscope-api-key

# DashScope OpenAI 兼容端点
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 使用的模型
LLM_MODEL=qwen3.5-plus

# ----------------------------------------------------------------------------
# Redis 缓存（必填，本地开发默认无密码）
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# 应用配置
# ----------------------------------------------------------------------------
# JWT 签名密钥（生产环境请换成随机强密钥）
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 应用运行环境（development / production）
ENV=development

# ----------------------------------------------------------------------------
# SQLite 数据库路径
# ----------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/agent.db

# ----------------------------------------------------------------------------
# Mock 数据层配置
# ----------------------------------------------------------------------------
# 故障注入概率（0.0 ~ 1.0），默认 10%
MOCK_FAULT_RATE=0.1
